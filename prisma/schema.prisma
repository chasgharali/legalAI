generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Firm {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  slug    String   @unique
  // Billing plan: pay_per_case | starter | growth | enterprise | trial
  plan    String   @default("trial")
  // Monthly cap on matters that can be processed. null = unlimited (enterprise).
  monthlyMatterLimit Int?     @default(2)
  // Counter reset by a monthly Inngest cron. Used to enforce limits.
  mattersUsedThisMonth Int    @default(0)
  monthlyResetAt   DateTime?
  // Free-text notes the super-admin keeps about this firm.
  adminNotes       String?
  billingContact   String?
  status           String    @default("active") // active | suspended | cancelled
  users   User[]
  matters Matter[]
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("fee_earner")
  firmId       String   @db.ObjectId
  firm         Firm     @relation(fields: [firmId], references: [id])
  matters      Matter[]
  gmail        GmailAccount?
  createdAt    DateTime @default(now())
}

model Matter {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  reference    String
  clientName   String
  clientDob    DateTime?
  incidentDate DateTime?
  claimType    String
  status       String            @default("draft")
  firmId       String            @db.ObjectId
  firm         Firm              @relation(fields: [firmId], references: [id])
  assignedToId String?           @db.ObjectId
  assignedTo   User?             @relation(fields: [assignedToId], references: [id])
  documents    MedicalDocument[]
  chronology   ChronologyEntry[]
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model MedicalDocument {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  matterId          String            @db.ObjectId
  matter            Matter            @relation(fields: [matterId], references: [id])
  fileName          String
  fileUrl           String
  tag               String
  pageCount         Int               @default(0)
  extractedText     String
  // Per-page text array: [{ page: 1, text: "..." }, ...]
  // Stored as Json so the chunker and chat retrieval can map back to real
  // page numbers instead of the previously hardcoded 15-pages-per-chunk lie.
  pageTexts         Json?
  // "digital" = pdf-parse extracted text directly,
  // "ocr"     = AWS Textract OCR was used (scanned PDF),
  // "mixed"   = some pages digital, some OCR'd,
  // "failed"  = no text could be extracted.
  extractionMethod  String            @default("digital")
  processingStatus  String            @default("pending")
  chronologyEntries ChronologyEntry[]
  jobs              ChronologyJob[]
  uploadedAt        DateTime          @default(now())
}

model ChronologyEntry {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  matterId            String          @db.ObjectId
  matter              Matter          @relation(fields: [matterId], references: [id])
  documentId          String          @db.ObjectId
  document            MedicalDocument @relation(fields: [documentId], references: [id])
  date                String
  dateApproximate     Boolean         @default(false)
  eventType           String
  providerName        String          @default("")
  providerRole        String          @default("")
  specialty           String          @default("")
  presentingComplaint String          @default("")
  diagnosis           String          @default("")
  treatmentGiven      String          @default("")
  followUpPlan        String          @default("")
  relevanceFlag       String          @default("unrelated")
  sourceDocumentTag   String          @default("")
  sourcePageNumber    Int?
  // Real start/end page derived from page-aware chunking.
  sourcePageStart     Int?
  sourcePageEnd       Int?
  verbatimExtract     String          @default("")
  notes               String          @default("")
  verified            Boolean         @default(false)
  editedByUser        Boolean         @default(false)
  // OpenAI text-embedding-3-small (1536 dims) of "presentingComplaint +
  // diagnosis + verbatimExtract", used for chat retrieval.
  embedding           Float[]
  createdAt           DateTime        @default(now())
}

// Tracks asynchronous chronology generation jobs (run by Node worker).
// Created when the API receives a generate request, updated by the worker.
model ChronologyJob {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  matterId        String          @db.ObjectId
  documentId      String          @db.ObjectId
  document        MedicalDocument @relation(fields: [documentId], references: [id])
  // queued | running | completed | failed
  status          String          @default("queued")
  totalChunks     Int             @default(0)
  completedChunks Int             @default(0)
  entriesCreated  Int             @default(0)
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
}

model CaseSummary {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  matterId    String   @unique @db.ObjectId
  content     String
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  matterId  String?  @db.ObjectId
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ============================================================================
// Marketing / outreach: prospects we haven't yet converted to customer firms.
// Populated from the UK clinical-negligence research CSV plus manual additions.
// ============================================================================

model MarketingProspect {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  firmName     String
  city         String?
  region       String?
  address      String?
  phone        String?
  email        String?
  website      String?
  side         String?   // Claimant | Defendant | Both
  specialism   String?
  // Pipeline status: cold | contacted | replied | demo_scheduled | converted | declined | bounced
  status       String   @default("cold")
  // ICP score 0-100: AvMA panel + Chambers Band 1 firms score high.
  icpScore     Int      @default(50)
  tags         String[]
  notes        String?
  // When the first email was sent. Used to compute "days since contacted".
  firstContactedAt DateTime?
  lastContactedAt  DateTime?
  lastRepliedAt    DateTime?
  // If a prospect converts to a paying firm, this points at that Firm row.
  convertedFirmId  String? @db.ObjectId
  source       String?  // "csv-2026-05" | "manual" | "referral"
  sends        EmailSend[]
  sequenceState ProspectSequenceState[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([firmName])
}

model EmailTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  // Personalization tokens: {{firm_name}}, {{city}}, {{specialism}}, {{first_name}}, {{sender_name}}
  subject   String
  body      String   // Markdown / plain text. Rendered to HTML on send.
  // Optional preview text shown in inbox preview pane.
  preheader String?
  // Tier of buyer this template targets (informational).
  tier      String?  // "avma" | "chambers_band_1" | "regional" | "general"
  sends     EmailSend[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailSequence {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  // List of steps in JSON: [{ stepIndex, templateId, delayDays }, ...]
  steps     Json
  isActive  Boolean  @default(true)
  prospectStates ProspectSequenceState[]
  createdAt DateTime @default(now())
}

// Tracks where a prospect is in a given sequence (which step they're on,
// when the next step fires). Inngest cron reads this and dispatches sends.
model ProspectSequenceState {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  prospectId  String   @db.ObjectId
  prospect    MarketingProspect @relation(fields: [prospectId], references: [id])
  sequenceId  String   @db.ObjectId
  sequence    EmailSequence     @relation(fields: [sequenceId], references: [id])
  currentStepIndex Int  @default(0)
  nextSendAt   DateTime?
  // active | paused | completed | stopped (e.g. prospect replied → stop)
  status      String   @default("active")
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@unique([prospectId, sequenceId])
}

model EmailSend {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  prospectId   String   @db.ObjectId
  prospect     MarketingProspect @relation(fields: [prospectId], references: [id])
  templateId   String?  @db.ObjectId
  template     EmailTemplate?    @relation(fields: [templateId], references: [id])
  // "gmail" (sent via connected Gmail account) | "resend" (transactional)
  // | "dev" (console only, no API key configured).
  provider     String   @default("dev")
  // Whichever provider's id we got back. For Gmail this is the message id
  // returned by users.messages.send; for Resend it's the email id.
  providerMsgId String?
  // RFC 5322 Message-ID header value. Used to match inbound replies by
  // their In-Reply-To / References headers.
  headerMessageId String?
  // Gmail thread id, used to cluster the conversation and detect replies
  // arriving in the same thread.
  threadId     String?
  fromEmail    String
  toEmail      String
  subject      String
  bodyText     String?  // Plain-text version (good for deliverability)
  bodyHtml     String
  // queued | sent | delivered | opened | clicked | bounced | replied | failed
  status       String   @default("queued")
  errorMessage String?
  sentAt       DateTime?
  openedAt     DateTime?
  lastOpenedAt DateTime?
  openCount    Int      @default(0)
  clickedAt    DateTime?
  lastClickedAt DateTime?
  clickCount   Int      @default(0)
  repliedAt    DateTime?
  bouncedAt    DateTime?
  // Spam-likelihood score (0=clean, 100=very spammy) computed before send.
  // See src/lib/spam-score.ts.
  spamScore    Int      @default(0)
  spamReasons  String[] // Human-readable flags, e.g. ["ALL CAPS subject"]
  replies      ConversationMessage[]
  createdAt    DateTime @default(now())
}

// ============================================================================
// Gmail OAuth: one Google account connected per admin user.
// Tokens are stored alongside the user row; the worker uses them to send
// outbound mail and to poll the inbox for replies.
// ============================================================================

model GmailAccount {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  userId        String  @unique @db.ObjectId
  user          User    @relation(fields: [userId], references: [id])
  emailAddress  String  @unique
  // OAuth tokens. Treat refreshToken as a credential. In production these
  // should be encrypted at rest — see docs note.
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime
  scopes        String[]
  // Gmail history id for incremental sync. Updated after each poll.
  lastHistoryId String?
  lastPolledAt  DateTime?
  status        String  @default("connected") // connected | revoked | error
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// An inbound message threaded with one of our outbound sends. Created by
// the reply-polling worker when a Gmail thread contains a message we did
// not send ourselves.
model ConversationMessage {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  emailSendId   String   @db.ObjectId
  emailSend     EmailSend @relation(fields: [emailSendId], references: [id])
  prospectId    String   @db.ObjectId
  // Gmail message id for dedupe.
  providerMsgId String   @unique
  threadId      String?
  fromEmail     String
  fromName      String?
  toEmail       String
  subject       String
  snippet       String?
  bodyText      String?
  // "inbound" (prospect → us) | "outbound" (we are tracking the original send too)
  direction     String   @default("inbound")
  // Gmail labels, e.g. ["INBOX", "IMPORTANT"]. Lets us filter spam/promotions.
  labels        String[]
  receivedAt    DateTime
  createdAt     DateTime @default(now())
}
